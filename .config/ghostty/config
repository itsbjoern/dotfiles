auto-update = check
font-family = Menlo
shell-integration = zsh
shell-integration-features = no-title

keybind = global:ctrl+grave_accent=toggle_quick_terminal
keybind = super+f=write_scrollback_file:open
keybind = shift+enter=text:\n

keybind = ctrl+z=ignore

keybind = cmd+shift+i=new_split:up
keybind = cmd+shift+k=new_split:down
keybind = cmd+shift+j=new_split:left
keybind = cmd+shift+l=new_split:right

keybind = cmd+i=goto_split:up
keybind = cmd+k=goto_split:down
keybind = cmd+j=goto_split:left
keybind = cmd+l=goto_split:right

keybind = cmd+z=toggle_split_zoom
