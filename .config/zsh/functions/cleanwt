cleanwt() {
  local force=0

  case "$1" in
    -f|--force)
      force=1
      shift
      ;;
  esac

  if [[ -n "$1" ]]; then
    echo "Usage: rmwt [-f|--force]" >&2
    return 1
  fi

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "cleanwt: not inside a git repository" >&2
    return 1
  fi

  if (( ! force )); then
    echo "cleanwt: this will discard ALL tracked changes and remove untracked files (ignored files like .venv are kept)."
    printf "Continue? [y/N] "
    local reply
    read reply
    case "$reply" in
      [Yy]*)
        ;;
      *)
        echo "cleanwt: aborted" >&2
        return 1
        ;;
    esac
  fi

  # Reset tracked files and remove untracked files, but keep ignored content like .venv.
  git reset --hard HEAD && git clean -fd
  git checkout "$(git_develop_branch)"
}

