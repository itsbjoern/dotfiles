pushwt() {
  local branch="$1"

  if [[ -z "$branch" ]]; then
    echo "Usage: pushwt BRANCH" >&2
    return 1
  fi

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "pushwt: not inside a git repository" >&2
    return 1
  fi

  local src_root dest_root
  dest_root="$(git rev-parse --show-toplevel)" || return 1

  # Locate the target worktree (the one we want to sync back to) by branch name.
  src_root="$(git worktree list --porcelain 2>/dev/null | \
    awk -v b="$branch" '
      $1=="worktree" { path=$2 }
      $1=="branch" && $2=="refs/heads/" b { print path }
    ' | head -n 1)"

  if [[ -z "$src_root" ]]; then
    echo "pushwt: no worktree found for branch '$branch'" >&2
    return 1
  fi

  if [[ "$src_root" == "$dest_root" ]]; then
    echo "pushwt: source worktree and current repo are the same" >&2
    return 1
  fi

  # Sanity check: we assume no commits were made here, so HEADs should match.
  local head_here head_there
  head_here="$(git -C "$dest_root" rev-parse HEAD 2>/dev/null)" || return 1
  head_there="$(git -C "$src_root" rev-parse HEAD 2>/dev/null)" || return 1
  if [[ "$head_here" != "$head_there" ]]; then
    echo "pushwt: HEAD in current repo and worktree do not match; refusing to sync" >&2
    echo "  here:  $head_here" >&2
    echo "  there: $head_there" >&2
    return 1
  fi

  # Collect tracked changes in the current repo relative to HEAD (both staged and unstaged).
  local tracked_changes
  tracked_changes="$(git -C "$dest_root" diff --name-status HEAD)" || return 1

  # Collect untracked (non-ignored) files in the current repo.
  local untracked_files
  untracked_files="$(git -C "$dest_root" status --porcelain | awk '$1=="??"{print $2}')" || return 1

  if ! command -v rsync >/dev/null 2>&1; then
    echo "pushwt: rsync is not installed or not on PATH" >&2
    return 1
  fi

  local rsync_list
  rsync_list="$(mktemp "${TMPDIR:-/tmp}/syncwt.XXXXXX")" || return 1

  # Build list of files to sync and handle deletions explicitly.
  local st file new old
  while IFS=$'\t' read -r st file new; do
    [[ -z "$st" ]] && continue

    case "$st" in
      M|A)
        printf '%s\n' "$file" >>"$rsync_list"
        ;;
      D)
        rm -f "$src_root/$file"
        ;;
      R*)
        old="$file"
        new="$new"
        rm -f "$src_root/$old"
        printf '%s\n' "$new" >>"$rsync_list"
        ;;
      *)
        if [[ -n "$file" && -f "$dest_root/$file" ]]; then
          printf '%s\n' "$file" >>"$rsync_list"
        fi
        ;;
    esac
  done <<< "$tracked_changes"

  # Add untracked files.
  local rel
  while IFS= read -r rel; do
    [[ -z "$rel" ]] && continue
    printf '%s\n' "$rel" >>"$rsync_list"
  done <<< "$untracked_files"

  # Push the collected files back into the worktree.
  rsync -a --files-from="$rsync_list" "$dest_root"/ "$src_root"/

  rm -f "$rsync_list"
}

